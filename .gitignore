# Rust
/target/

# Node
node_modules/
*.tgz
.npmrc

# Python
__pycache__/
*.pyc
*.pyo
build/
dist/
*.egg-info/
.venv/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Agent tooling (claude-flow / claude worktrees / per-user config)
.claude/
.claude-flow/
**/.claude-flow/

# ...but klasp's own dogfooded gate files MUST be tracked, so worktrees and
# remote agents inherit the install. These un-ignore patterns are scoped to
# the repo-root .claude/ only (subdirectory .claude/ folders stay ignored).
!/.claude/
!/.claude/settings.json
!/.claude/hooks/
!/.claude/hooks/klasp-gate.sh

# AgentDB / ruvector local cache (rebuilt per-session)
ruvector.db
ruvector.db-shm
ruvector.db-wal
