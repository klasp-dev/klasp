{
  "theme": "dark",
  "permissions": {
    "allow": ["Read", "Glob", "Grep"],
    "deny": []
  },
  "env": {
    "FALLOW_AUDIT": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/fallow-gate.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "fallow lint --staged"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "fallow record"
          }
        ]
      }
    ]
  }
}
